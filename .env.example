# Project Glitch Environment Configuration
# Copy this to .env and fill in your values

# OpenRouter API key (required for cloud chat)
# Get yours at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_key_here

# Model to use on OpenRouter (default: same model as Hermes)
GLITCH_OPENROUTER_MODEL=openrouter/owl-alpha

# Backend: "openrouter" (cloud) or "llama_cpp" (local)
GLITCH_LLM_BACKEND=openrouter

# llama.cpp local server (only needed if backend is llama_cpp)
LLM_HOST=localhost
LLM_PORT=8080
